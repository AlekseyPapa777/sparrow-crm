let currentLang = 'uk';

function setLang(lang, btn) {
  currentLang = lang;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyLang();
  renderDashboard();
  showToast(lang === 'uk' ? '🇺🇦 Українська мова' : '🇷🇺 Русский язык');
}

function t(key) {
  return LANGS[currentLang][key] || LANGS['uk'][key] || key;
}

function applyLang() {
  const L = LANGS[currentLang];

  // Logo
  const logoSub = document.getElementById('logo-sub');
  if(logoSub) logoSub.textContent = L['logo-sub'];

  // Nav labels
  const nm = document.getElementById('nav-label-main');
  if(nm) nm.textContent = L['nav-label-main'];
  const na = document.getElementById('nav-label-analytics');
  if(na) na.textContent = L['nav-label-analytics'];

  // Nav items with data-t
  document.querySelectorAll('[data-t]').forEach(el => {
    const key = el.getAttribute('data-t');
    if(L[key]) el.textContent = L[key];
  });

  // Topbar
  const addBtn = document.querySelector('.topbar .btn-primary');
  if(addBtn) addBtn.textContent = L['btn-add-farmer'];
  const searchInput = document.getElementById('globalSearch');
  if(searchInput) searchInput.placeholder = L['search-placeholder'];

  // Stat labels
  const statLabels = {
    'stat-farmers-label': document.querySelectorAll('.stat-label')[0],
    'stat-closed-label': document.querySelectorAll('.stat-label')[1],
    'stat-active-label': document.querySelectorAll('.stat-label')[2],
    'stat-alerts-label': document.querySelectorAll('.stat-label')[3],
  };
  Object.entries(statLabels).forEach(([key, el]) => { if(el && L[key]) el.textContent = L[key]; });

  // Page title
  const currentView = document.querySelector('.view.active');
  if(currentView) {
    const viewId = currentView.id.replace('view-', '');
    const titleEl = document.getElementById('pageTitle');
    if(titleEl && L['pageTitle-' + viewId]) titleEl.textContent = L['pageTitle-' + viewId];
  }

  // Modals
  const modalTitles = {
    'addModal': 'add-farmer-title',
    'dealModal': 'add-deal-title',
    'alertModal': 'add-alert-title',
  };
  Object.entries(modalTitles).forEach(([modalId, key]) => {
    const modal = document.getElementById(modalId);
    if(modal) {
      const title = modal.querySelector('.modal-title');
      if(title && L[key]) title.textContent = L[key];
    }
  });

  // Prices buttons
  document.querySelectorAll('[onclick="savePrices()"]').forEach(btn => {
    btn.textContent = L['prices-save'];
  });

  // Export buttons (reports view)
  const exportBtns = document.querySelectorAll('#view-reports .btn');
  const exportKeys = ['export-farmers','export-deals','export-all','import-excel','export-json','import-json'];
  exportBtns.forEach((btn, i) => {
    if(exportKeys[i] && L[exportKeys[i]]) {
      if(btn.tagName === 'LABEL') {
        // Keep file input, just update text node
        const textNode = Array.from(btn.childNodes).find(n => n.nodeType === 3);
        if(textNode) textNode.textContent = L[exportKeys[i]];
      } else {
        btn.textContent = L[exportKeys[i]];
      }
    }
  });
}

// ========== WORLD ANALYTICS ==========
async function getAIAnalytics() {
  const el = document.getElementById('ai-analytics-content');
  el.innerHTML = '<div style="text-align:center;padding:20px;color:var(--gold)">⏳ Отримую аналітику від AI...</div>';

  const prompt = `Ти - експерт з аграрних ринків України та світу. Дай коротку аналітику цін на зернові та олійні культури на поточний тиждень (червень 2026) у форматі:

1. ПШЕНИЦЯ: поточна ситуація + прогноз
2. КУКУРУДЗА: поточна ситуація + прогноз  
3. РІПАК: поточна ситуація + прогноз
4. СОНЯШНИК: поточна ситуація + прогноз
5. СОЯ: поточна ситуація + прогноз
6. ГОЛОВНИЙ ВИСНОВОК для українського фермера

Актуальні дані: Пшениця CBOT $5.74/бушель (-13.6% за місяць), Кукурудза $4.11 (мінімум), Соя $10.30. В Україні: пшениця 10 066 грн/т, кукурудза 10 522 грн/т. Ріпак на 5-тижневому мінімумі. Відповідай стисло, практично, українською мовою.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await response.json();
    const text = data.content?.[0]?.text || 'Помилка отримання даних';
    el.innerHTML = '<div style="white-space:pre-wrap;font-size:12px;line-height:1.8">' + text + '</div>';
    document.getElementById('analytics-updated').textContent = 'Оновлено: ' + new Date().toLocaleString('uk');
  } catch(err) {
    el.innerHTML = '<div style="color:var(--red)">❌ Помилка підключення. Перевірте інтернет.</div>';
  }
}

function refreshAnalytics() {
  showToast('🔄 Оновлення даних...');
  document.getElementById('analytics-updated').textContent = 'Оновлено: ' + new Date().toLocaleString('uk');
  getAIAnalytics();
}

