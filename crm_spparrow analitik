function renderFarmers(filter) {
  if(filter) currentFilter = filter;
  let list = farmers;
  if(currentFilter !== 'all') list = farmers.filter(f => f.status === currentFilter);
  document.getElementById('farmerCount').textContent = list.length + ' фермерів';
  const tb = document.getElementById('farmersTable');
  if(!list.length) {
    tb.innerHTML = '<tr><td colspan="7" style="padding:30px;text-align:center;color:var(--text-dim)">👨‍🌾 Немає фермерів у цій категорії</td></tr>';
    return;
  }
  tb.innerHTML = list.map((f,i) => `
    <tr onclick="showFarmerDetail(${f.id})">
      <td>
        <div class="farmer-cell">
          <div class="farmer-avatar" style="background:${COLORS[i%COLORS.length]}">${f.name[0]}</div>
          <div>
            <div class="farmer-name">${f.name}</div>
            <div class="farmer-region">${f.phone} · ${f.company || '—'}</div>
          </div>
        </div>
      </td>
      <td>${f.crop}</td>
      <td>${f.volume ? f.volume + ' т' : '—'}</td>
      <td>${f.region || '—'}</td>
      <td><span class="badge ${statusBadge(f.status)}">${statusLabel(f.status)}</span></td>
      <td><span class="stars">${'⭐'.repeat(f.rating)}</span></td>
      <td>
        <div style="display:flex;gap:6px">
          <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();callFarmer('${f.phone}')">📞</button>
