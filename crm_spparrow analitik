// ========== ACTIONS ==========
function filterFarmers(filter, el) {
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderFarmers(filter);
}

function advanceDeal(id) {
  const d = deals.find(x => x.id === id);
  if(d && d.stage < 3) { d.stage++; save(); renderDeals(); renderDashboard(); showToast('✅ Угоду просунуто: ' + STAGES[d.stage]); }
}

function deleteFarmer(id) {
  farmers = farmers.filter(f => f.id !== id);
  save(); renderFarmers(); renderDashboard(); showToast('🗑️ Фермера видалено', 'red');
}

function deleteDeal(id) {
  deals = deals.filter(d => d.id !== id);
  save(); renderDeals(); renderDashboard(); showToast('🗑️ Угоду видалено', 'red');
}

function deleteAlert(id) {
  alerts = alerts.filter(a => a.id !== id);
  save(); renderAlerts(); updateAlertBadge();
}

function callFarmer(phone) { showToast('📞 Дзвінок: ' + phone); }

function handleSearch(val) {
  if(!val) return;
  const results = farmers.filter(f => f.name.toLowerCase().includes(val.toLowerCase()) || f.phone.includes(val));
  if(results.length) showToast('🔍 Знайдено: ' + results.map(f=>f.name).join(', '));
}

function updateAlertBadge() {
  const count = alerts.length + 3;
  document.getElementById('alertBadge').textContent = count;
  document.getElementById('stat-alerts').textContent = count;
  const mb = document.getElementById('mobileBadge');
  if(mb) mb.textContent = count;
}

// ========== HELPERS ==========
function statusBadge(s) { return {hot:'badge-red',warm:'badge-gold',cold:'badge-blue'}[s] || 'badge-gray'; }
function statusLabel(s) { return {hot:'🔥 Гарячий',warm:'🌡️ Теплий',cold:'❄️ Холодний'}[s] || s; }

function showToast(msg, color) {
  const t = document.createElement('div');
  t.className = 'toast';
  t.style.borderColor = color === 'red' ? 'var(--red)' : 'var(--green)';
  t.textContent = msg;
  document.getElementById('toastContainer').appendChild(t);
  setTimeout(() => t.remove(), 3500);
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if(e.target === o) o.classList.remove('open'); });
});

// ========== EXCEL EXPORT/IMPORT ==========
function loadSheetJS(cb) {
  if(window.XLSX) { cb(); return; }
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
  s.onload = cb;
  document.head.appendChild(s);
}

function exportFarmersXLSX() {
  loadSheetJS(() => {
    if(!farmers.length) { showToast('⚠️ База фермерів порожня', 'red'); return; }
    const data = farmers.map(f => ({
      'ПІБ': f.name,
      'Телефон': f.phone,
      'Господарство': f.company || '',
      'Район/Область': f.region || '',
      'Культура': f.crop,
      'Обсяг (т)': f.volume || 0,
      'Статус': statusLabel(f.status).replace(/[🔥🌡️❄️]/g,'').trim(),
      'Рейтинг': f.rating + '/5',
      'Нотатки': f.notes || '',
      'Дата додавання': f.created
    }));
    const ws = XLSX.utils.json_to_sheet(data);
    ws['!cols'] = [{wch:30},{wch:18},{wch:25},{wch:30},{wch:15},{wch:12},{wch:12},{wch:10},{wch:40},{wch:15}];
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Фермери');
    XLSX.writeFile(wb, 'Sparrow_Фермери_' + today() + '.xlsx');
    showToast('✅ Файл завантажено: Фермери.xlsx');
  });
}

