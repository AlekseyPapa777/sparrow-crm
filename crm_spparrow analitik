function importXLSX(input) {
  loadSheetJS(() => {
    const file = input.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb = XLSX.read(e.target.result, {type:'binary'});
        const sheetName = wb.SheetNames[0];
        const rows = XLSX.utils.sheet_to_json(wb.Sheets[sheetName]);
        let added = 0;
        rows.forEach(row => {
          const name = row['ПІБ'] || row['Назва'] || row['Фермер'] || '';
          const phone = row['Телефон'] || row['Тел'] || '';
          if(name) {
            farmers.push({
              id: Date.now() + Math.random(),
              name: String(name),
              phone: String(phone),
              company: String(row['Господарство'] || ''),
              region: String(row['Район/Область'] || row['Район'] || ''),
              crop: String(row['Культура'] || 'Пшениця'),
              volume: Number(row['Обсяг (т)'] || row['Обсяг'] || 0),
              status: 'warm',
              rating: parseInt(row['Рейтинг']) || 3,
              notes: String(row['Нотатки'] || ''),
              created: new Date().toLocaleDateString('uk')
            });
            added++;
          }
        });
        save();
        renderFarmers();
        renderDashboard();
        showToast(`✅ Імпортовано ${added} фермерів з Excel`);
      } catch(err) {
        showToast('❌ Помилка читання файлу', 'red');
      }
    };
    reader.readAsBinaryString(file);
    input.value = '';
  });
}

function exportJSON() {
  const data = JSON.stringify({farmers, deals, alerts, exported: new Date().toISOString()}, null, 2);
  const blob = new Blob([data], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'Sparrow_CRM_Backup_' + today() + '.json';
  a.click();
  showToast('💾 Резервну копію збережено');
}

function importJSON(input) {
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if(data.farmers) farmers = data.farmers;
      if(data.deals) deals = data.deals;
      if(data.alerts) alerts = data.alerts;
      save();
      renderDashboard();
      renderFarmers();
      showToast('✅ Дані відновлено з копії!');
    } catch {
      showToast('❌ Невірний формат файлу', 'red');
    }
  };
  reader.readAsText(file);
  input.value = '';
}

