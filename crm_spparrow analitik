<script>
// ========== DATA ==========
let farmers = JSON.parse(localStorage.getItem('sparrow_farmers') || '[]');
let deals = JSON.parse(localStorage.getItem('sparrow_deals') || '[]');
let alerts = JSON.parse(localStorage.getItem('sparrow_alerts') || '[]');
let currentFilter = 'all';

const COLORS = ['#F5A623','#27AE60','#2980B9','#8E44AD','#E74C3C','#16A085','#D35400'];
const STAGES = ['📞 Перший контакт','🔥 Переговори','📄 Договір','✅ Закрито'];
const STAGE_IDS = ['k0','k1','k2','k3'];

// ========== VIEWS ==========
function showView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  const titles = {dashboard:'Дашборд',farmers:'База фермерів',deals:'Угоди — Канбан',alerts:'Нагадування',prices:'Моніторинг цін',reports:'Звіти'};
  document.getElementById('pageTitle').textContent = titles[name] || name;
  document.querySelectorAll('.nav-item').forEach(n => { if(n.textContent.trim().includes(titles[name]?.split(' ')[0])) n.classList.add('active'); });
  if(name === 'farmers') renderFarmers();
  if(name === 'deals') renderDeals();
  if(name === 'alerts') renderAlerts();
  if(name === 'reports') renderReports();
  if(name === 'dashboard') renderDashboard();
}

// ========== MODALS ==========
function openAddModal() {
  document.getElementById('addModal').classList.add('open');
  ['f-name','f-phone','f-company','f-region','f-volume','f-notes'].forEach(id => document.getElementById(id).value = '');
}

function openDealModal() {
  const sel = document.getElementById('d-farmer');
  sel.innerHTML = '<option value="">Оберіть фермера...</option>';
  farmers.forEach(f => { sel.innerHTML += `<option value="${f.id}">${f.name}</option>`; });
  document.getElementById('dealModal').classList.add('open');
  ['d-volume','d-price','d-notes'].forEach(id => document.getElementById(id).value = '');
}

function openAlertModal() {
  document.getElementById('alertModal').classList.add('open');
  const now = new Date(); now.setMinutes(0);
  document.getElementById('a-date').value = now.toISOString().slice(0,16);
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ========== SAVE ==========
function saveFarmer() {
  const name = document.getElementById('f-name').value.trim();
  const phone = document.getElementById('f-phone').value.trim();
  if(!name || !phone) { showToast('⚠️ Введіть ПІБ та телефон', 'red'); return; }
  const farmer = {
    id: Date.now(),
    name, phone,
    company: document.getElementById('f-company').value,
    region: document.getElementById('f-region').value,
    crop: document.getElementById('f-crop').value,
    volume: document.getElementById('f-volume').value || 0,
    status: document.getElementById('f-status').value,
    rating: parseInt(document.getElementById('f-rating').value),
    notes: document.getElementById('f-notes').value,
    created: new Date().toLocaleDateString('uk')
  };
  farmers.push(farmer);
  save();
  closeModal('addModal');
  renderFarmers();
  renderDashboard();
  showToast('✅ Фермера додано: ' + name);
}

function saveDeal() {
  const farmerId = document.getElementById('d-farmer').value;
  const volume = document.getElementById('d-volume').value;
  if(!farmerId || !volume) { showToast('⚠️ Оберіть фермера та вкажіть обсяг', 'red'); return; }
  const farmer = farmers.find(f => f.id == farmerId);
  const price = document.getElementById('d-price').value || 0;
  const deal = {
    id: Date.now(),
    farmerId,
    farmerName: farmer ? farmer.name : 'Невідомий',
    crop: document.getElementById('d-crop').value,
    volume: parseFloat(volume),
    price: parseFloat(price),
    total: parseFloat(volume) * parseFloat(price),
    port: document.getElementById('d-port').value,
    stage: parseInt(document.getElementById('d-stage').value),
    notes: document.getElementById('d-notes').value,
    created: new Date().toLocaleDateString('uk')
  };
  deals.push(deal);
  save();
  closeModal('dealModal');
  renderDeals();
  renderDashboard();
  showToast('✅ Угоду додано');
}

function saveAlert() {
  const title = document.getElementById('a-title').value.trim();
  if(!title) { showToast('⚠️ Введіть назву нагадування', 'red'); return; }
  const a = {
    id: Date.now(),
    title,
    desc: document.getElementById('a-desc').value,
    date: document.getElementById('a-date').value,
    priority: document.getElementById('a-priority').value
  };
  alerts.push(a);
  save();
  closeModal('alertModal');
  renderAlerts();
  updateAlertBadge();
  showToast('🔔 Нагадування додано');
}

function savePrices() {
  showToast('💾 Ціни збережено');
  const hist = document.getElementById('priceHistory');
  const now = new Date().toLocaleString('uk');
  const pw = document.getElementById('pw-odesa').value;
  const pc = document.getElementById('pc-odesa').value;
  if(pw || pc) {
    hist.innerHTML = `<div style="padding:8px;border-left:3px solid var(--gold);margin-bottom:8px;font-size:12px"><strong>${now}</strong><br>${pw ? '🌾 Пшениця Одеса: ' + pw + ' грн/т<br>' : ''}${pc ? '🌽 Кукурудза: ' + pc + ' грн/т' : ''}</div>` + hist.innerHTML;
  }
}

function save() {
  localStorage.setItem('sparrow_farmers', JSON.stringify(farmers));
  localStorage.setItem('sparrow_deals', JSON.stringify(deals));
  localStorage.setItem('sparrow_alerts', JSON.stringify(alerts));
}

// ========== RENDER ==========
function renderDashboard() {
  document.getElementById('stat-farmers').textContent = farmers.length;
  document.getElementById('stat-closed').textContent = deals.filter(d => d.stage === 3).length;
  document.getElementById('stat-active').textContent = deals.filter(d => d.stage < 3).length;
  document.getElementById('stat-alerts').textContent = alerts.length + 3;

  // dash deals
  const dd = document.getElementById('dashDeals');
  if(!deals.length) { dd.innerHTML = '<div class="empty-state"><div class="icon">🤝</div><p>Додайте першу угоду</p></div>'; }
