function renderDeals() {
  STAGE_IDS.forEach((id, idx) => {
    const col = document.getElementById(id);
    const stageDeal = deals.filter(d => d.stage === idx);
    document.getElementById(id + '-count').textContent = stageDeal.length;
    if(!stageDeal.length) {
      col.innerHTML = '<div style="padding:16px;text-align:center;color:var(--text-dim);font-size:12px">Немає угод</div>';
      return;
    }
    col.innerHTML = stageDeal.map(d => `
      <div class="deal-card">
        <div class="deal-title">${d.farmerName}</div>
        <div class="deal-meta">${d.crop} · ${d.port}</div>
        <div class="deal-amount">${d.volume} т ${d.price ? '· ' + (d.price).toLocaleString() + ' грн/т' : ''}</div>
        <div class="deal-footer">
          <span style="font-size:10px;color:var(--text-dim)">${d.created}</span>
          <div style="display:flex;gap:4px">
            ${idx < 3 ? `<button class="btn btn-green btn-sm" onclick="advanceDeal(${d.id})">→</button>` : ''}
            <button class="btn btn-ghost btn-sm" onclick="deleteDeal(${d.id})">🗑️</button>
          </div>
        </div>
      </div>
    `).join('');
  });
}

